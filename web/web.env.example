# app-ads-web (DMZ) — runtime config for the static form + reverse proxy.
# Copy to web.env on the DMZ VM and fill in. All values are CONFIG, not secrets
# (the web tier holds ZERO credentials — DESIGN.md §3 inv 2). Injected at container
# start by docker-entrypoint.sh.

# Public Cloudflare Turnstile SITE key (safe to ship to the browser). NOT the secret.
TURNSTILE_SITE_KEY=0x0000000000000000000000

# Upload host the browser POSTs artwork to (the upload proxy). Origin only, no path.
UPLOAD_URL=https://ads-upload.gpsaswimming.org

# Season submission deadline (ISO 8601). After this the form shows a "closed" state;
# the API rejects late POSTs as a backstop. Must match the API's SUBMISSION_DEADLINE.
SUBMISSION_DEADLINE=2026-07-31T23:59:59-04:00

# Ads API upstream (host:port) that nginx reverse-proxies /api/* to, across the
# inter-tier firewall. Cleartext HTTP between tiers by design. Resolved lazily so the
# form still serves if the API is momentarily unreachable.
API_UPSTREAM=ads-api:8080

# DNS resolver nginx uses to look up API_UPSTREAM. Default 127.0.0.11 is Docker's
# embedded DNS (correct for the compose deployment). On a bare VM using system DNS,
# set this to that resolver (e.g. 127.0.0.53 for systemd-resolved, or your LAN DNS).
# RESOLVER=127.0.0.11
