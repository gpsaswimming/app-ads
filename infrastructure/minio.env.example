# minio.env — DMZ object storage (DESIGN.md §7). Copy to minio.env, chmod 600.
# NEVER commit the filled copy. S = secret, C = config.
#
# The app does NOT use these root credentials — minio-setup.sh creates a scoped service
# account for the Ads API. Root is only for bootstrap + LAN console/admin.

MINIO_ROOT_USER=changeme-root-user             # S  admin bootstrap
MINIO_ROOT_PASSWORD=changeme-root-password     # S

# Public upload host, so presigned-POST signatures validate when the browser uploads
# via the proxy (which preserves the Host header).
MINIO_SERVER_URL=https://ads-upload.gpsaswimming.org   # C

# ObjectCreated webhook → the Ads API (App tier). The "_ADS" suffix names the target;
# minio-setup.sh subscribes the gpsa-ads bucket to arn:minio:sqs::ADS:webhook.
MINIO_NOTIFY_WEBHOOK_ENABLE_ADS=on                                                # C
MINIO_NOTIFY_WEBHOOK_ENDPOINT_ADS=http://ads-api.gpsa.local:8080/internal/uploaded # C
# MUST equal ads-api.env MINIO_TO_API_SECRET (the API verifies this on the webhook).
MINIO_NOTIFY_WEBHOOK_AUTH_TOKEN_ADS=changeme-shared-webhook-secret               # S
