# nocodb.env — Data tier (DESIGN.md §7). Copy to nocodb.env, chmod 600.
# NEVER commit the filled copy. S = secret, C = config.

NC_AUTH_JWT_SECRET=changeme-jwt-secret     # S  session/JWT signing secret

# External DB connection. Omit to use the bundled SQLite in the nocodb_data volume
# (fine for this single-table, low-volume workload).
# NC_DB=pg://host:5432?u=user&p=pass&d=nocodb   # S

# NC_PUBLIC_URL=http://nocodb.gpsa.local:8080    # C  optional; base URL for links
