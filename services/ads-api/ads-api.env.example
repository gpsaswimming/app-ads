# ads-api.env — Application-tier secrets & config (DESIGN.md §7).
# Copy to `ads-api.env`, fill in real values, chmod 600. NEVER commit the filled copy.
# The Ads API is the ONLY credentialed component: every secret in the system lives here.
# S = secret (harm if leaked)   C = config (environment-specific, not sensitive)

# --- MinIO / object storage ---
MINIO_ENDPOINT_INTERNAL=http://minio.gpsa.local:9000        # C  internal SDK host (renames, getObject)
MINIO_ENDPOINT_PUBLIC=https://ads-upload.gpsaswimming.org   # C  public presign-target host
MINIO_ACCESS_KEY=changeme-scoped-svcacct-key                # S  scoped service account (NOT root)
MINIO_SECRET_KEY=changeme-scoped-svcacct-secret             # S
MINIO_TO_API_SECRET=changeme-shared-webhook-secret          # S  shared with minio.env; auth on the ObjectCreated webhook
# MINIO_BUCKET=gpsa-ads                                     # C  optional; defaults to gpsa-ads

# --- NocoDB / metadata database ---
NOCODB_URL=http://nocodb.gpsa.local:8080                    # C  database base URL
NOCODB_TOKEN=changeme-nocodb-api-token                      # S  database API token
NOCODB_BASE_ID=changeme-base-id                             # C  provisioned base id (from setup)
NOCODB_ADS_TABLE_ID=changeme-ads-table-id                   # C  provisioned Ads table id (from setup)

# --- Cloudflare Turnstile ---
TURNSTILE_SECRET=changeme-turnstile-secret                  # S  server-side siteverify secret

# --- Google Gemini (appropriateness check) ---
GEMINI_API_KEY=changeme-gemini-api-key                      # S
# GEMINI_MODEL=gemini-2.5-flash                             # C  optional; current Gemini Flash tier

# --- Email (SMTP) ---
SMTP_URL=smtp://user:pass@smtp.example.com:587              # S  transport URL (contains credentials)
# MAIL_FROM=GPSA Scoreboard Ads <no-reply@gpsaswimming.org> # C  optional; From: header
ADS_NOTIFY_EMAIL=ad-chair@example.org                       # C  internal "new submission" recipient

# --- Business config (per season / deploy-time) ---
GPSA_CHECK_ADDRESS=GPSA, PO Box 0000, City VA 00000         # C  mailing address inserted into the CHECK email
SUBMISSION_DEADLINE=2026-07-31T23:59:59-04:00               # C  ISO datetime; form closes + API rejects after
# MEET_NAME=2026 City Meet                                  # C  optional; stamped on each row
# PRICE_FULL_CENTS=9000                                     # C  optional; full-screen price (default 9000 = $90)
# PRICE_HALF_CENTS=5000                                     # C  optional; half-screen price (default 5000 = $50)

# --- Server tuning (optional) ---
# PORT=8080                                                 # C
# MAX_UPLOAD_BYTES=52428800                                 # C  presign size cap (default 50 MB)
# PRESIGN_EXPIRY_SECONDS=900                                # C  presigned POST validity (default 15 min)
